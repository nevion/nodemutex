[Unit]
Description=Node Mutex - exclusive access queue
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/nodemutex server
RuntimeDirectory=nodemutex
RuntimeDirectoryMode=0755
ExecStartPost=/bin/sh -c 'for i in 1 2 3 4 5; do [ -S /run/nodemutex/nodemutex.sock ] && break; sleep 0.1; done; chmod 0777 /run/nodemutex/nodemutex.sock'
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
